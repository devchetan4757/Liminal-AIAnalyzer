# Required — powers the plain-English summaries and general Q&A
# Free, no credit card needed: sign up at console.groq.com
GROQ_API_KEY=

# Optional — free tier keys. The app works without them, it just skips
# that source and relies on the ones that ARE configured.
VT_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=

# Required for URLhaus, MalwareBazaar, and ThreatFox (abuse.ch now requires
# an Auth-Key for all of these). Get one for free at https://auth.abuse.ch/
ABUSECH_API_KEY=

# Frontend origin(s) allowed to call this API, comma separated
CORS_ORIGINS=http://localhost:5173
